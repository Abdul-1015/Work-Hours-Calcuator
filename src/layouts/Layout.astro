---
import '../styles/global.css';
import ThemeToggle from '../components/react/ThemeToggle';
import LanguageSwitcher from '../components/astro/LanguageSwitcher.astro';
import { getTranslations, type Locale, locales, localeNames } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  locale?: Locale;
}

const locale = (Astro.params.locale || 'en') as Locale;
const t = getTranslations(locale);

const {
  title = t.site.title,
  description = t.site.description,
  canonicalUrl = Astro.url.href,
} = Astro.props;

const currentPath = Astro.url.pathname;
const basePath = locale === 'en' ? currentPath : currentPath.replace(`/${locale}`, '') || '/';

const webAppSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Calculate Work Hours",
  "url": "https://calcworkhours.com",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "inLanguage": locale,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "featureList": [
    "Single shift time calculation",
    "Weekly timesheet calculator",
    "Work hours calculator with lunch break",
    "Automatic overnight shift detection",
    "Decimal hours conversion",
    "Copy results to clipboard",
    "CSV export for weekly timesheets"
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": t.faq.q1.replace(/<[^>]*>/g, ''),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t.faq.a1.replace(/<[^>]*>/g, '')
      }
    },
    {
      "@type": "Question",
      "name": t.faq.q2.replace(/<[^>]*>/g, ''),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t.faq.a2.replace(/<[^>]*>/g, '')
      }
    },
    {
      "@type": "Question",
      "name": t.faq.q3.replace(/<[^>]*>/g, ''),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t.faq.a3.replace(/<[^>]*>/g, '')
      }
    },
    {
      "@type": "Question",
      "name": "Is this work hours calculator free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our work hours calculator is completely free to use. There are no hidden fees, no registration required, and all calculations are performed locally in your browser for complete privacy."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this as a weekly work hours calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. Our weekly work hours calculator allows you to log shifts for Monday through Sunday, automatically calculating daily totals and weekly summaries including total hours worked, decimal hours, and total minutes."
      }
    }
  ]
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calcworkhours.com"
    }
  ]
});
---
<!doctype html>
<html lang={locale} dir={locale === 'ar' ? 'rtl' : 'ltr'} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.copy.svg" />
    <link rel="shortcut icon" href="/favicon.copy.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="WorkHrs" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap.xml" />
    
    {/* SEO Meta Tags */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="WorkHours Calculator" />
    <meta name="theme-color" content="#22c55e" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Alternate Language Links for SEO */}
    {locales.map((loc) => {
      const altPath = loc === 'en' ? basePath : `/${loc}${basePath}`;
      const altUrl = `${Astro.url.origin}${altPath}`;
      return (
        <link rel="alternate" hreflang={loc} href={altUrl} />
      );
    })}
    <link rel="alternate" hreflang="x-default" href={`${Astro.url.origin}${basePath}`} />

    {/* Open Graph / Facebook */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${Astro.url.origin}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.hero.title1} />
    <meta property="og:site_name" content="WorkHours" />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale} />
    {locales.filter(loc => loc !== locale).map((loc) => (
      <meta property="og:locale:alternate" content={loc === 'en' ? 'en_US' : loc} />
    ))}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.url.origin}/og-image.png`} />
    <meta name="twitter:image:alt" content={t.hero.title1} />

    {/* Preconnect & Google Fonts */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Manrope:wght@800;900&display=swap" rel="stylesheet" />

    {/* JSON-LD Structured Data for WebApplication Schema */}
    <script type="application/ld+json" set:html={webAppSchema} />

    {/* JSON-LD Structured Data for FAQ Schema */}
    <script type="application/ld+json" set:html={faqSchema} />

    {/* JSON-LD Structured Data for BreadcrumbList Schema */}
    <script type="application/ld+json" set:html={breadcrumbSchema} />

    {/* Google Analytics */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-26HWW430MK" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-26HWW430MK');
    </script>
  </head>
  <body>
    {/* Accessibility Skip Link */}
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-4 focus:left-4 focus:bg-primary focus:text-ink focus:px-4 focus:py-2 focus:rounded-md focus:font-bold focus:shadow-md"
    >
      {t.nav.skipToMain}
    </a>
    
    <div class="min-h-screen flex flex-col justify-between">
      {/* Header / Nav Area (Wise-inspired, sticky on page) */}
      <header class="w-full bg-canvas border-b border-canvas-soft sticky top-0 z-40 dark:bg-[#111311] dark:border-canvas-soft/10" role="banner">
        <div class="max-w-5xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
          <a href={locale === 'en' ? '/' : `/${locale}`} class="flex items-center gap-2 focus-visible:outline-hidden" aria-label="WorkHours Homepage">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-ink font-bold text-lg select-none" aria-hidden="true">
              W
            </div>
            <span class="font-wise font-black text-xl tracking-tight text-ink dark:text-canvas">
              WorkHours<span class="text-primary font-black">.</span>
            </span>
          </a>

          <nav class="flex items-center space-x-4 md:space-x-6" role="navigation" aria-label="Main Navigation">
            <a href={`${locale === 'en' ? '' : `/${locale}`}/#how-it-works`} class="text-xs font-bold text-ink hover:text-primary-neutral transition-default dark:text-canvas-soft dark:hover:text-primary">{t.nav.howItWorks}</a>
            <a href={`${locale === 'en' ? '' : `/${locale}`}/#faq`} class="text-xs font-bold text-ink hover:text-primary-neutral transition-default dark:text-canvas-soft dark:hover:text-primary">{t.nav.faq}</a>
            <a href={`${locale === 'en' ? '' : `/${locale}`}/about`} class="hidden md:inline-flex text-xs font-bold text-ink hover:text-primary-neutral transition-default dark:text-canvas-soft dark:hover:text-primary">{t.nav.about}</a>
            <a href={`${locale === 'en' ? '' : `/${locale}`}/contact`} class="hidden md:inline-flex text-xs font-bold text-ink hover:text-primary-neutral transition-default dark:text-canvas-soft dark:hover:text-primary">{t.nav.contact}</a>
            <ThemeToggle client:load />
            <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
            <a 
              href={`${locale === 'en' ? '' : `/${locale}`}/#calculator`} 
              class="hidden sm:inline-flex px-4 py-2 text-xs font-bold bg-primary text-ink hover:bg-primary-hover active:bg-primary-neutral rounded-xl transition-default"
            >
              {t.nav.useCalculator}
            </a>
          </nav>
        </div>
      </header>

      {/* Main Page Slot */}
      <main id="main-content" class="flex-1" role="main">
        <slot />
      </main>

    </div>
  </body>
</html>
