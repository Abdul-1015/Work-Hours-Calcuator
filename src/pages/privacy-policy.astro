---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/astro/Footer.astro';
import { getTranslations } from '../i18n/utils';

const t = getTranslations('en');
---

<Layout 
  title={t.privacy.title}
  description={t.site.description}
  locale="en"
>
  <main class="w-full bg-canvas min-h-screen dark:bg-[#111311]">
    <div class="max-w-4xl mx-auto px-4 md:px-6 py-16 md:py-24">
      <h1 class="text-3xl md:text-4xl font-wise font-black tracking-tight mb-8 text-ink dark:text-canvas">
        {t.privacy.title}
      </h1>
      <p class="text-sm text-mute mb-8 dark:text-canvas-soft/60">{t.privacy.lastUpdated}</p>
      
      <div class="prose prose-lg max-w-none text-body dark:text-canvas-soft/80 space-y-6">
        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.introTitle}</h2>
        <p set:html={t.privacy.intro}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.collectTitle}</h2>
        <p><strong class="text-ink dark:text-canvas">{t.privacy.collectBold}</strong> {t.privacy.collect}</p>
        <ul class="list-disc pl-6 space-y-2">
          {t.privacy.collectList.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p set:html={t.privacy.collectNote}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.useTitle}</h2>
        <p set:html={t.privacy.use}></p>
        <ul class="list-disc pl-6 space-y-2">
          {t.privacy.useList.map((item: string) => (
            <li set:html={item}></li>
          ))}
        </ul>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.storageTitle}</h2>
        <p set:html={t.privacy.storage}></p>
        <ul class="list-disc pl-6 space-y-2">
          {t.privacy.storageList.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p set:html={t.privacy.storageNote}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.thirdPartyTitle}</h2>
        <p set:html={t.privacy.thirdParty}></p>
        <ul class="list-disc pl-6 space-y-2">
          {t.privacy.thirdPartyList.map((item: string) => (
            <li set:html={item}></li>
          ))}
        </ul>
        <p set:html={t.privacy.thirdPartyNote}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.securityTitle}</h2>
        <p set:html={t.privacy.security}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.childrenTitle}</h2>
        <p set:html={t.privacy.children}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.changesTitle}</h2>
        <p set:html={t.privacy.changes}></p>

        <h2 class="text-xl font-bold text-ink dark:text-canvas mt-8">{t.privacy.contactTitle}</h2>
        <p set:html={t.privacy.contact}></p>
      </div>
    </div>
  </main>
  <Footer t={t.footer} locale="en" />
</Layout>
