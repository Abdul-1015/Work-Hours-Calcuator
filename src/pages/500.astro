---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';

const t = getTranslations('en');

interface Props {
  error?: string;
}

const { error = "An unexpected error occurred" } = Astro.props;
---

<Layout 
  title="Error — Work Hours Calculator"
  description="Something went wrong."
  locale="en"
>
  <main class="w-full bg-canvas min-h-screen flex items-center justify-center dark:bg-[#111311]">
    <div class="max-w-lg mx-auto px-4 md:px-6 text-center py-16">
      <div class="mb-8">
        <span class="text-8xl md:text-9xl font-wise font-black text-negative/20 dark:text-negative/10 select-none">500</span>
      </div>

      <div class="w-20 h-20 mx-auto mb-8 bg-canvas-soft rounded-2xl flex items-center justify-center dark:bg-[#1a1d1a]">
        <svg class="w-10 h-10 text-negative/60 dark:text-negative/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
      </div>

      <h1 class="text-2xl md:text-3xl font-wise font-black tracking-tight mb-4 text-ink dark:text-canvas">
        {t.errors.somethingWrongTitle}
      </h1>
      <p class="text-body mb-4 dark:text-canvas-soft/70">
        {t.errors.somethingWrongMessage}
      </p>
      {error && (
        <p class="text-xs text-mute bg-canvas-soft px-4 py-2 rounded-lg mb-8 dark:bg-[#1a1d1a] dark:text-canvas-soft/50">
          Error: {error}
        </p>
      )}

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/" 
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-bold bg-primary text-ink hover:bg-primary-hover active:bg-primary-neutral rounded-xl transition-default"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          {t.errors.goHome}
        </a>
        <button 
          type="button"
          onclick="window.location.reload()"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-bold border border-ink/20 text-ink hover:bg-canvas-soft rounded-xl transition-default dark:border-canvas-soft/20 dark:text-canvas dark:hover:bg-canvas-soft/10 cursor-pointer"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          {t.errors.tryAgain}
        </button>
      </div>

      <div class="mt-12 pt-8 border-t border-canvas-soft dark:border-canvas-soft/10">
        <p class="text-xs text-mute mb-4 dark:text-canvas-soft/50">{t.errors.contactIfPersists}</p>
        <div class="flex flex-wrap justify-center gap-4 text-xs">
          <a href="/contact" class="text-primary hover:underline">{t.errors.contactSupport}</a>
          <a href="/" class="text-primary hover:underline">{t.errors.backToHome}</a>
        </div>
      </div>
    </div>
  </main>
</Layout>
