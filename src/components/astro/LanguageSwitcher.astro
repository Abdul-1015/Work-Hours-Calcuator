---
import { locales, localeNames, localeFlags, type Locale } from '../../i18n/utils';

interface Props {
  currentLocale: Locale;
  currentPath: string;
}

const { currentLocale, currentPath } = Astro.props;

const basePath = currentLocale === 'en'
  ? currentPath
  : currentPath.replace(`/${currentLocale}`, '') || '/';
---

<div class="relative" id="lang-switcher">
  <button
    type="button"
    id="lang-toggle"
    class="flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-bold text-ink hover:bg-canvas-soft rounded-lg transition-default dark:text-canvas-soft dark:hover:bg-canvas-soft/10 cursor-pointer"
    aria-label="Change language"
    aria-expanded="false"
    aria-haspopup="listbox"
  >
    <span class="text-sm">{localeFlags[currentLocale]}</span>
    <svg class="w-3 h-3 text-mute dark:text-canvas-soft/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-dropdown"
    class="hidden absolute right-0 top-full mt-1 w-48 bg-canvas rounded-xl shadow-lg border border-canvas-soft z-50 py-1.5 max-h-80 overflow-y-auto dark:bg-[#1a1d1a] dark:border-canvas-soft/10"
    role="listbox"
    aria-label="Select language"
  >
    {locales.map((locale) => {
      const url = locale === 'en' ? basePath : `/${locale}${basePath}`;
      const isActive = locale === currentLocale;
      return (
        <a
          href={url}
          class:list={[
            "flex items-center gap-2.5 px-3 py-2 text-xs font-semibold transition-default",
            isActive
              ? "bg-primary-pale text-ink dark:bg-primary/15 dark:text-primary"
              : "text-body hover:bg-canvas-soft hover:text-ink dark:text-canvas-soft/70 dark:hover:bg-canvas-soft/10 dark:hover:text-canvas"
          ]}
          role="option"
          aria-selected={isActive}
          lang={locale}
        >
          <span class="text-sm">{localeFlags[locale]}</span>
          <span>{localeNames[locale]}</span>
        </a>
      );
    })}
  </div>
</div>

<script is:inline>
  (function() {
    const toggle = document.getElementById('lang-toggle');
    const dropdown = document.getElementById('lang-dropdown');

    if (!toggle || !dropdown) return;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.classList.contains('hidden');
      dropdown.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target) && !toggle.contains(e.target)) {
        dropdown.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
