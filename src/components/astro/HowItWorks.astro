---
// src/components/astro/HowItWorks.astro
import { Clock, Coffee, ShieldAlert, BadgeDollarSign } from 'lucide-react';

interface Props {
  t: {
    title: string;
    description: string;
    step1Title: string;
    step1Description: string;
    step1Tag: string;
    step2Title: string;
    step2Description: string;
    step2Tag: string;
    step3Title: string;
    step3Description: string;
    step3Tag: string;
    step4Title: string;
    step4Description: string;
    step4Tag: string;
  };
}

const { t } = Astro.props;
---
<section class="w-full bg-canvas py-16 md:py-24 border-t border-canvas-soft dark:bg-[#111311] dark:border-canvas-soft/10" aria-labelledby="how-it-works-title">
  <div class="max-w-5xl mx-auto px-4 md:px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 id="how-it-works-title" class="text-3xl md:text-4xl font-wise font-black tracking-tight mb-4 text-ink dark:text-canvas">
        {t.title}
      </h2>
      <p class="text-body text-base leading-relaxed dark:text-canvas-soft/80">
        {t.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {/* Step 1 */}
      <div class="bg-canvas-soft rounded-xl p-6 md:p-8 flex flex-col justify-between border border-canvas-soft/40 hover:border-ink/10 transition-default dark:bg-[#1a1d1a] dark:border-canvas-soft/10 dark:hover:border-canvas-soft/20">
        <div>
          <div class="w-12 h-12 bg-canvas rounded-full flex items-center justify-center mb-6 shadow-xs dark:bg-ink-deep">
            <Clock className="w-6 h-6 text-ink dark:text-canvas" />
          </div>
          <h3 class="text-xl font-bold tracking-tight mb-3 text-ink dark:text-canvas">{t.step1Title}</h3>
          <p class="text-body text-sm leading-relaxed mb-4 dark:text-canvas-soft/80" set:html={t.step1Description}></p>
        </div>
        <span class="text-xs font-bold text-mute uppercase tracking-wider dark:text-canvas-soft/50">{t.step1Tag}</span>
      </div>

      {/* Step 2 */}
      <div class="bg-canvas-soft rounded-xl p-6 md:p-8 flex flex-col justify-between border border-canvas-soft/40 hover:border-ink/10 transition-default dark:bg-[#1a1d1a] dark:border-canvas-soft/10 dark:hover:border-canvas-soft/20">
        <div>
          <div class="w-12 h-12 bg-canvas rounded-full flex items-center justify-center mb-6 shadow-xs dark:bg-ink-deep">
            <Coffee className="w-6 h-6 text-ink dark:text-canvas" />
          </div>
          <h3 class="text-xl font-bold tracking-tight mb-3 text-ink dark:text-canvas">{t.step2Title}</h3>
          <p class="text-body text-sm leading-relaxed mb-4 dark:text-canvas-soft/80" set:html={t.step2Description}></p>
        </div>
        <span class="text-xs font-bold text-mute uppercase tracking-wider dark:text-canvas-soft/50">{t.step2Tag}</span>
      </div>

      {/* Step 3 */}
      <div class="bg-canvas-soft rounded-xl p-6 md:p-8 flex flex-col justify-between border border-canvas-soft/40 hover:border-ink/10 transition-default dark:bg-[#1a1d1a] dark:border-canvas-soft/10 dark:hover:border-canvas-soft/20">
        <div>
          <div class="w-12 h-12 bg-canvas rounded-full flex items-center justify-center mb-6 shadow-xs dark:bg-ink-deep">
            <ShieldAlert className="w-6 h-6 text-ink dark:text-canvas" />
          </div>
          <h3 class="text-xl font-bold tracking-tight mb-3 text-ink dark:text-canvas">{t.step3Title}</h3>
          <p class="text-body text-sm leading-relaxed mb-4 dark:text-canvas-soft/80" set:html={t.step3Description}></p>
        </div>
        <span class="text-xs font-bold text-mute uppercase tracking-wider dark:text-canvas-soft/50">{t.step3Tag}</span>
      </div>

      {/* Step 4 */}
      <div class="bg-canvas-soft rounded-xl p-6 md:p-8 flex flex-col justify-between border border-canvas-soft/40 hover:border-ink/10 transition-default dark:bg-[#1a1d1a] dark:border-canvas-soft/10 dark:hover:border-canvas-soft/20">
        <div>
          <div class="w-12 h-12 bg-canvas rounded-full flex items-center justify-center mb-6 shadow-xs dark:bg-ink-deep">
            <BadgeDollarSign className="w-6 h-6 text-ink dark:text-canvas" />
          </div>
          <h3 class="text-xl font-bold tracking-tight mb-3 text-ink dark:text-canvas">{t.step4Title}</h3>
          <p class="text-body text-sm leading-relaxed mb-4 dark:text-canvas-soft/80" set:html={t.step4Description}></p>
        </div>
        <span class="text-xs font-bold text-mute uppercase tracking-wider dark:text-canvas-soft/50">{t.step4Tag}</span>
      </div>
    </div>
  </div>
</section>
