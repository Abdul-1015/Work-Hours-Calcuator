---
// src/components/astro/Faq.astro
interface Props {
  t: {
    title: string;
    subtitle: string;
    q1: string;
    a1: string;
    q2: string;
    a2: string;
    q3: string;
    a3: string;
    q4: string;
    a4: string;
  };
}

const { t } = Astro.props;
---
<section class="w-full bg-canvas-soft py-16 md:py-24 border-t border-ink/5 dark:bg-[#1a1d1a] dark:border-canvas-soft/10" aria-labelledby="faq-title">
  <div class="max-w-3xl mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <h2 id="faq-title" class="text-3xl md:text-4xl font-wise font-black tracking-tight mb-4 text-ink dark:text-canvas">
        {t.title}
      </h2>
      <p class="text-body text-base dark:text-canvas-soft/80">
        {t.subtitle}
      </p>
    </div>

    {/* Accordion Questions using semantic Details/Summary */}
    <div class="space-y-4">
      
      <details class="group bg-canvas rounded-xl border border-canvas-soft/80 overflow-hidden transition-default [&_summary::-webkit-details-marker]:hidden dark:bg-[#111311] dark:border-canvas-soft/10">
        <summary class="flex justify-between items-center p-6 text-base font-bold text-ink cursor-pointer list-none select-none group-open:border-b group-open:border-canvas-soft dark:text-canvas dark:group-open:border-canvas-soft/10">
          <span>{t.q1}</span>
          <span class="transition-default group-open:rotate-180">
            <svg class="w-5 h-5 text-mute dark:text-canvas-soft/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="p-6 text-sm text-body leading-relaxed bg-canvas-soft/10 dark:text-canvas-soft/80">
          <p set:html={t.a1}></p>
        </div>
      </details>

      <details class="group bg-canvas rounded-xl border border-canvas-soft/80 overflow-hidden transition-default [&_summary::-webkit-details-marker]:hidden dark:bg-[#111311] dark:border-canvas-soft/10">
        <summary class="flex justify-between items-center p-6 text-base font-bold text-ink cursor-pointer list-none select-none group-open:border-b group-open:border-canvas-soft dark:text-canvas dark:group-open:border-canvas-soft/10">
          <span>{t.q2}</span>
          <span class="transition-default group-open:rotate-180">
            <svg class="w-5 h-5 text-mute dark:text-canvas-soft/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="p-6 text-sm text-body leading-relaxed bg-canvas-soft/10 dark:text-canvas-soft/80">
          <p set:html={t.a2}></p>
        </div>
      </details>

      <details class="group bg-canvas rounded-xl border border-canvas-soft/80 overflow-hidden transition-default [&_summary::-webkit-details-marker]:hidden dark:bg-[#111311] dark:border-canvas-soft/10">
        <summary class="flex justify-between items-center p-6 text-base font-bold text-ink cursor-pointer list-none select-none group-open:border-b group-open:border-canvas-soft dark:text-canvas dark:group-open:border-canvas-soft/10">
          <span>{t.q3}</span>
          <span class="transition-default group-open:rotate-180">
            <svg class="w-5 h-5 text-mute dark:text-canvas-soft/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="p-6 text-sm text-body leading-relaxed bg-canvas-soft/10 dark:text-canvas-soft/80">
          <p set:html={t.a3}></p>
        </div>
      </details>

      <details class="group bg-canvas rounded-xl border border-canvas-soft/80 overflow-hidden transition-default [&_summary::-webkit-details-marker]:hidden dark:bg-[#111311] dark:border-canvas-soft/10">
        <summary class="flex justify-between items-center p-6 text-base font-bold text-ink cursor-pointer list-none select-none group-open:border-b group-open:border-canvas-soft dark:text-canvas dark:group-open:border-canvas-soft/10">
          <span>{t.q4}</span>
          <span class="transition-default group-open:rotate-180">
            <svg class="w-5 h-5 text-mute dark:text-canvas-soft/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="p-6 text-sm text-body leading-relaxed bg-canvas-soft/10 dark:text-canvas-soft/80">
          <p set:html={t.a4}></p>
        </div>
      </details>

    </div>
  </div>
</section>
