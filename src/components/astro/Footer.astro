---
// src/components/astro/Footer.astro
import type { Locale } from '../../i18n/utils';

const YEAR = new Date().getFullYear();

interface Props {
  t: {
    description: string;
    tools: string;
    workHoursCalculator: string;
    howItWorks: string;
    company: string;
    aboutUs: string;
    contactUs: string;
    privacyPolicy: string;
    termsConditions: string;
    copyright: string;
    about: string;
    contact: string;
    privacy: string;
    terms: string;
  };
  locale: Locale;
}

const { t, locale } = Astro.props;
const prefix = locale === 'en' ? '' : `/${locale}`;
---
<footer class="w-full bg-ink text-canvas-soft/80 py-16 border-t border-canvas-soft/10 dark:bg-[#0a0c0a] dark:text-canvas-soft/70 dark:border-canvas-soft/5" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="max-w-5xl mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      {/* Brand Column */}
      <div class="md:col-span-2 space-y-4">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-ink font-bold text-lg select-none">
            W
          </div>
          <span class="font-wise font-black text-xl tracking-tight text-canvas">
            WorkHours<span class="text-primary font-black">.</span>
          </span>
        </div>
        <p class="text-xs text-canvas-soft/50 leading-relaxed max-w-sm">
          {t.description}
        </p>
      </div>

      {/* Nav Link Columns */}
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-canvas mb-4">{t.tools}</h3>
        <ul class="space-y-2 text-xs">
          <li><a href={`${prefix}/#calculator`} class="hover:text-primary transition-default">{t.workHoursCalculator}</a></li>
          <li><a href={`${prefix}/#how-it-works`} class="hover:text-primary transition-default">{t.howItWorks}</a></li>
          <li><a href={`${prefix}/#faq`} class="hover:text-primary transition-default">{t.faq}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-canvas mb-4">{t.company}</h3>
        <ul class="space-y-2 text-xs">
          <li><a href={`${prefix}/about`} class="hover:text-primary transition-default">{t.aboutUs}</a></li>
          <li><a href={`${prefix}/contact`} class="hover:text-primary transition-default">{t.contactUs}</a></li>
          <li><a href={`${prefix}/privacy-policy`} class="hover:text-primary transition-default">{t.privacyPolicy}</a></li>
          <li><a href={`${prefix}/terms`} class="hover:text-primary transition-default">{t.termsConditions}</a></li>
        </ul>
      </div>
    </div>

    {/* Bottom row */}
    <div class="border-t border-canvas-soft/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-[11px] text-canvas-soft/40">
        &copy; {YEAR} WorkHours Calculator. All rights reserved. Locally calculated.
      </span>
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-[11px] text-canvas-soft/40">
        <a href={`${prefix}/about`} class="hover:text-canvas transition-default">{t.about}</a>
        <a href={`${prefix}/contact`} class="hover:text-canvas transition-default">{t.contact}</a>
        <a href={`${prefix}/privacy-policy`} class="hover:text-canvas transition-default">{t.privacy}</a>
        <a href={`${prefix}/terms`} class="hover:text-canvas transition-default">{t.terms}</a>
      </div>
    </div>
  </div>
</footer>
